doctype html
html
  head
    title=DOBERview
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC' crossorigin='anonymous')
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js' integrity='sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM' crossorigin='anonymous')
    script(src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous" type="text/javascript")
    script(src='https://kit.fontawesome.com/73df3ddf45.js' crossorigin='anonymous')
    script(src="javascripts/default_scripts.js" type="text/javascript")
    script(src="https://kit.fontawesome.com/abb8282784.js" crossorigin="anonymous" type="text/javascript")

    meta(name="application-name" content="pagetitle")

    block extrahead

  body
    div.overlay
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.sticky-top
        .container.mx-1
          a.navbar-brand(href='/sensors') DOBERview
          button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navmenu")
            span.navbar-toggler-icon
          div.collapse.navbar-collapse(id="#navmenu")
            ul.navbar-nav
              li.nav-item
                a.nav-link(href='/subsystem') Systems
              li.nav-item
                a.nav-link(href='/pipeline') Pipeline
              li.nav-item
                a.nav-link(href='/contacts') Shifters
              li.nav-item
                a.nav-link(href='/grafana') Grafana
              li.nav-item
                a.nav-link(href='/daq') DAQ
            ul.navbar-nav.ms-auto
              li.nav-item
                select.form-select.bg-warning
                  option(value='pancake' selected='') PANCAKE
                  option(value='xebra') XeBRA
                  option(value='gemse') GeMSE
    div#content(style="padding-left:5px;padding-right:5px;padding-top:0px;padding-bottom:0px")
      #readingbox.modal.fade(tabindex='-1' aria-labelledby='readingboxLabel' aria-hidden='true')
        .modal-dialog.modal-xl
          .modal-content
            .modal-header
              h5#readingboxLabel.modal-title
                .form-check.form-switch
                  input#reading_status.form-check-input(type='checkbox')
                  label.form-check-label(for='reading_status')
                    span#detail_reading_name
              button.btn-close(type='button' data-bs-dismiss='modal' aria-label='Close')
            .modal-body.row
              .col-lg-6
                form#update_reading_form
                  table
                    tbody
                      tr
                        th Description
                        th
                          input(type="text" id="reading_desc" name="reading_desc")
                      tr
                        th.py-3 Readout interval &nbsp
                        th
                          input(type="number" id="readout_interval" name="readout_interval" min="0.1" max="300" size=3 width=3)
                      tr
                        th Runmode
                        th
                          #runmode.btn-group(role='group')
                            input#default_btn.btn-check(type='radio' name='runmode_btn' value='default' autocomplete='off')
                            label.btn.btn-outline-primary(for='default_btn') Default
                            input#testing_btn.btn-check(type='radio' name='runmode_btn'  value='testing' autocomplete='off')
                            label.btn.btn-outline-primary(for='testing_btn') Testing
              .col-lg-6
                .d-flex.flex-row-reverse
                  .dropdown
                    button#reading_history.btn.btn-outline-secondary.dropdown-toggle(type='button' data-bs-toggle='dropdown' aria-expanded='false')
                      | 10m
                    ul.dropdown-menu(aria-labelledby='dropdownMenu2')
                      li
                        button.dropdown-item(type='button' onclick='DrawReadingHistory("None", "10m")') 10m
                      li
                        button.dropdown-item(type='button' onclick='DrawReadingHistory("None", "1h")') 1h
                      li
                        button.dropdown-item(type='button' onclick='DrawReadingHistory("None", "1d")') 1d
                      li
                        button.dropdown-item(type='button' onclick='DrawReadingHistory("None", "1w")') 1w
                    button#refresh_btn.btn.btn-outline-secondary.mx-1
                      i.fa.fa-sync-alt
                div.main_container.reading_chart#reading_chart
            .modal-footer
              button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Close
              button.btn.btn-primary(type='button') Save changes

      #sensorbox.modal.fade
        .modal-dialog
          .modal-content
              .modal-header
                h5#sensorboxLabel.modal-title
                  span#detail_sensor_name
                button.btn-close(type='button' data-bs-dismiss='modal' aria-label='Close')
              .modal-body
                form#update_sensor_form
                  fieldset#sensor_eth
                    table
                      tr
                        th.py-3 IP &nbsp
                        td
                          input(type="text" id="sensor_ip" name="sensor_ip" pattern="^(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$")
                      tr
                        th Port &nbsp
                        td
                          input(type="number" id="sensor_port" name="sensor_port" min="1025" max="65535" step="1")
                  fieldset#sensor_serial
                    table
                        tr
                          th TTY &nbsp
                          td
                            input(type="text" id="sensor_tty" name="sensor_tty")
                        tr
                          th.py-3 Baud &nbsp
                          td
                            select.form-select.form-select-sm(id="sensor_baud" name="sensor_baud")
                              option(value="9600") 9600
                              option(value="19200") 19,200
                        tr
                          th SerialID &nbsp
                          td
                           input(type="text" id="sensor_serial_id" name="sensor_serial_id")
              .modal-footer
                button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Close
                button.btn.btn-primary(type='button') Save changes

      #hostbox.modal.fade
        .modal-dialog
          .modal-content
            .modal-header
              h5#hostboxLabel.modal-title
                span#detail_host_name
              button.btn-close(type='button' data-bs-dismiss='modal' aria-label='Close')
            .modal-body.row
              .col-md-6
                ul.list-group
                  li.list-group-item An item
                  li.list-group-item A second item
                  li.list-group-item A third item
                  li.list-group-item A fourth item
                  li.list-group-item And a fifth one
              .col-md-6
                ul.list-group
                  li.list-group-item An item
                  li.list-group-item A second item
                  li.list-group-item A third item
                  li.list-group-item A fourth item
                  li.list-group-item And a fifth one

      block content

  script.
    $(".dropdown-menu li .dropdown-item").click(function () {
      var selText = $(this).text();
      $(this).parents('.dropdown').find('.dropdown-toggle').html(selText);
    });
    $("#refresh_btn").click(function () {
      var interval = $(this).parents('.dropdown').find('.dropdown-toggle').text();
      DrawReadingHistory('None', interval);
    });
    $("#readingbox").on('hide.bs.modal', function(){
      $("#reading_history").html('10m')
    });