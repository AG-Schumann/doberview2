extends layout

block extrahead
  script(src="javascripts/full_system.js", type="text/javascript")
  script(src="javascripts/highcharts.js", type="text/javascript")
  script(src="https://unpkg.com/mustache@latest", type="text/javascript")
  link(href="stylesheets/highcharts.css", rel="stylesheet")


block content
  section.bg-light.text-dark.p-3
    .main-container
      .row
        .col-lg-8
          .card
            .card-body
              .d-flex.justify-content-between
                div
                  span
                    strong Group by: &nbsp;
                  #groupButtons.btn-group(role='group')
                    input#btnradio1.btn-check(type='radio' name='btnradio' value='sensor' autocomplete='off' onclick='UpdateOnce()' checked='')
                    label.btn.btn-outline-primary(for='btnradio1') Sensor
                    input#btnradio2.btn-check(type='radio' name='btnradio' value='subsystem' autocomplete='off' onclick='UpdateOnce()')
                    label.btn.btn-outline-primary(for='btnradio2') Subsystem
                    input#btnradio3.btn-check(type='radio' name='btnradio'  value='topic' autocomplete='off' onclick='UpdateOnce()')
                    label.btn.btn-outline-primary(for='btnradio3') Quantity
                div.form-check.form-switch
                  label.h5.form-check-label(for='show_unmonitored')
                    strong show unmonitored

                    input#show_unmonitored.form-check-input(type='checkbox')
            .card-text
              table.table.table-striped.table-hover#reading_table
        .col-lg-4
          .row
            .card
              .card-body
                .h3.card-title Hosts
              .card-text
                table.table.table-hover.table-borderless#host_table
            .card
              .card-body
                .h3.card-title Shifters
              .card-text
                ul.list-group.list-group-flush
                  li.list-group-item
                    h4 Primary
                    i.fa.fa-user
                    | &nbsp John Doe
                    br
                    i.fa.fa-envelope
                    | &nbsp john.doe@googlemail.com
                    br
                    i.fa.fa-phone
                    | &nbsp 012312345678
                  li.list-group-item
                    h4 Secondary
                    i.fa.fa-user
                    | &nbsp Jane Doe
                    br
                    i.fa.fa-envelope
                    | &nbsp jane.doe@mail.com
                    br
                    i.fa.fa-phone
                    | &nbsp 012312345678
                  li.list-group-item
                    h4 Alarm Duty
                    i.fa.fa-user
                    | &nbsp Elroy Freakinglongname
                    br
                    i.fa.fa-envelope
                    | &nbsp; elroy.freakinglongname@longmail.com
                    br
                    i.fa.fa-phone
                    | &nbsp 012312345678
  script.

    $(document).ready(function () {

      GetGroupedReadings('sensor');
      PopulateReadings();
      GetHosts();
      setInterval(UpdateOnce, 5000);
      setInterval(GetHosts, 5000);

    });

    $("#groupButtons :input").change(function () {
      GetGroupedReadings(this.value);
    });
